{
    "name": "ljutaev/pure-php-booking-api",
    "description": "Hotel Booking REST API — pure PHP 8.3, Clean Architecture + DDD",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^1",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
